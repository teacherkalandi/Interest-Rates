rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /{document=**} {
      allow read, write: if false;
    }

    match /settings/rates {
      allow read: if true;
      allow write: if 
        request.auth != null && 
        request.auth.token.email_verified == true && 
        request.auth.token.email == 'teacherkalandi@gmail.com';
    }
  }
}
